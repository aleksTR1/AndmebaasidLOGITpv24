-- 1. PROTSEDUUR: Lisab kiiresti uue kategooria
CREATE PROCEDURE LisaKategooria @nimi VARCHAR(50) AS 
    INSERT INTO kategooria VALUES (@nimi);

	-- 2. PROTSEDUUR: Kustutab kategooria ID alusel
CREATE PROCEDURE KustutaKategooria @id INT AS 
    DELETE FROM kategooria WHERE kategooria_id = @id;

	-- Lisab uue kategooria nimega 'Supid'
EXEC LisaKategooria 'Supid';

-- Kustutab kategooria, mille ID on 1
EXEC KustutaKategooria 6;

